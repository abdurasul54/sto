{% extends 'base.html.twig' %}

{% block title %}Workers index{% endblock %}

{% block body %}
    <h1>Workers index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Surname</th>
                <th>Phone_number</th>
                <th>Img</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for worker in workers %}
            <tr>
                <td>{{ worker.id }}</td>
                <td>{{ worker.name }}</td>
                <td>{{ worker.surname }}</td>
                <td>{{ worker.phoneNumber }}</td>
                <td>{{ worker.img }}</td>
                <td>
                    <a href="{{ path('app_workers_show', {'id': worker.id}) }}">show</a>
                    <a href="{{ path('app_workers_edit', {'id': worker.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_workers_new') }}">Create new</a>
{% endblock %}
